import { useState } from 'react'
import { crimeIncidents, additionalAccused, AccusedPerson, CrimeIncident } from '../data/policeData'

export default function SuspectTracker() {
  const [selectedSuspect, setSelectedSuspect] = useState<AccusedPerson | null>(null)
  const [searchQuery, setSearchQuery] = useState('')

  // Get all accused from all cases
  const allAccused = [
    ...crimeIncidents.flatMap(c => c.accused),
    ...additionalAccused,
  ]

  const filtered = allAccused.filter(a =>
    a.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
    a.alias.some(al => al.toLowerCase().includes(searchQuery.toLowerCase())) ||
    a.id.toLowerCase().includes(searchQuery.toLowerCase())
  )

  const suspectCases = selectedSuspect
    ? crimeIncidents.filter(c =>
        c.accused.some(a => a.id === selectedSuspect.id) ||
        selectedSuspect.criminalHistory.some(h => h.caseId === c.id)
      )
    : []

  return (
    <div>
      <div className="mb-4">
        <h1 style={{ fontSize: '1.5rem', fontWeight: 700 }}>Suspect & Accused Tracker</h1>
        <p style={{ color: 'var(--text-secondary)', fontSize: '0.875rem' }}>Track known offenders, repeat criminals, and case linkages</p>
      </div>

      <div className="dashboard-grid" style={{ gridTemplateColumns: '350px 1fr' }}>
        {/* Suspect List */}
        <div className="card">
          <div style={{ marginBottom: '0.75rem' }}>
            <input
              type="text"
              placeholder="Search by name, alias, or ID..."
              value={searchQuery}
              onChange={e => setSearchQuery(e.target.value)}
              style={{
                width: '100%',
                padding: '0.5rem 0.75rem',
                background: 'var(--bg-primary)',
                border: '1px solid var(--border-color)',
                borderRadius: '0.375rem',
                color: 'var(--text-primary)',
                fontSize: '0.8rem',
              }}
            />
          </div>
          <div style={{ display: 'flex', flexDirection: 'column', gap: '0.5rem', maxHeight: '600px', overflowY: 'auto' }}>
            {filtered.map(suspect => (
              <div
                key={suspect.id}
                onClick={() => setSelectedSuspect(suspect)}
                style={{
                  padding: '0.75rem',
                  background: selectedSuspect?.id === suspect.id ? 'rgba(59,130,246,0.15)' : 'rgba(0,0,0,0.2)',
                  borderRadius: '0.5rem',
                  border: selectedSuspect?.id === suspect.id ? '1px solid var(--accent-blue)' : '1px solid var(--border-color)',
                  cursor: 'pointer',
                }}
              >
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                  <span style={{ fontWeight: 600, fontSize: '0.9rem' }}>{suspect.name}</span>
                  <span style={{
                    fontSize: '0.65rem',
                    fontWeight: 700,
                    padding: '0.15rem 0.4rem',
                    borderRadius: '0.25rem',
                    background: suspect.isRepeatOffender ? 'rgba(239,68,68,0.2)' : 'rgba(34,197,94,0.2)',
                    color: suspect.isRepeatOffender ? 'var(--accent-red)' : 'var(--accent-green)',
                  }}>
                    {suspect.isRepeatOffender ? 'REPEAT' : 'FIRST'}
                  </span>
                </div>
                <div style={{ display: 'flex', gap: '0.75rem', marginTop: '0.35rem', fontSize: '0.7rem', color: 'var(--text-secondary)' }}>
                  <span>Age: {suspect.age}</span>
                  <span>Risk: <b style={{ color: suspect.riskScore > 80 ? 'var(--accent-red)' : suspect.riskScore > 50 ? 'var(--accent-yellow)' : 'var(--accent-green)' }}>{suspect.riskScore}/100</b></span>
                  <span>Cases: {suspect.criminalHistory.length + crimeIncidents.filter(c => c.accused.some(a => a.id === suspect.id)).length}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Suspect Detail */}
        <div>
          {selectedSuspect ? (
            <>
              <div className="card" style={{ marginBottom: '1rem' }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>
                  <div>
                    <div style={{ display: 'flex', alignItems: 'center', gap: '0.75rem' }}>
                      <div style={{
                        width: 48, height: 48, borderRadius: '50%',
                        background: 'linear-gradient(135deg, var(--accent-red), var(--accent-purple))',
                        display: 'flex', alignItems: 'center', justifyContent: 'center',
                        fontSize: '1.2rem', fontWeight: 700, color: '#fff',
                      }}>
                        {selectedSuspect.name.split(' ').map(n => n[0]).join('')}
                      </div>
                      <div>
                        <h2 style={{ fontSize: '1.2rem', fontWeight: 700 }}>{selectedSuspect.name}</h2>
                        <div style={{ display: 'flex', gap: '0.5rem', fontSize: '0.75rem', color: 'var(--text-secondary)' }}>
                          <span>ID: {selectedSuspect.id}</span>
                          <span>• Age: {selectedSuspect.age}</span>
                          <span>• {selectedSuspect.occupation}</span>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div style={{ textAlign: 'right' }}>
                    <div style={{ fontSize: '0.7rem', color: 'var(--text-secondary)' }}>Risk Score</div>
                    <div style={{
                      fontSize: '2rem', fontWeight: 700,
                      color: selectedSuspect.riskScore > 80 ? 'var(--accent-red)' : selectedSuspect.riskScore > 50 ? 'var(--accent-yellow)' : 'var(--accent-green)',
                    }}>{selectedSuspect.riskScore}</div>
                  </div>
                </div>
              </div>

              <div className="dashboard-grid" style={{ gridTemplateColumns: '1fr 1fr' }}>
                <div className="card">
                  <h3 style={{ fontSize: '0.9rem', fontWeight: 600, marginBottom: '0.75rem', color: 'var(--accent-cyan)' }}>📋 Personal Details</h3>
                  <div style={{ fontSize: '0.8rem', lineHeight: 2 }}>
                    <div><span style={{ color: 'var(--text-secondary)' }}>Full Name:</span> {selectedSuspect.name}</div>
                    <div><span style={{ color: 'var(--text-secondary)' }}>Alias:</span> {selectedSuspect.alias.join(', ')}</div>
                    <div><span style={{ color: 'var(--text-secondary)' }}>Address:</span> {selectedSuspect.address}</div>
                    <div><span style={{ color: 'var(--text-secondary)' }}>Phone:</span> {selectedSuspect.phoneNumber}</div>
                    <div><span style={{ color: 'var(--text-secondary)' }}>Social Media:</span> {selectedSuspect.socialMediaHandles.join(', ') || 'None'}</div>
                    <div><span style={{ color: 'var(--text-secondary)' }}>Occupation:</span> {selectedSuspect.occupation}</div>
                    <div><span style={{ color: 'var(--text-secondary)' }}>Marks:</span> {selectedSuspect.identificationMarks}</div>
                  </div>
                </div>

                <div className="card">
                  <h3 style={{ fontSize: '0.9rem', fontWeight: 600, marginBottom: '0.75rem', color: 'var(--accent-purple)' }}>🧠 Modus Operandi & Risk</h3>
                  <div style={{ fontSize: '0.8rem', lineHeight: 1.8 }}>
                    <div style={{ padding: '0.5rem', background: 'rgba(0,0,0,0.2)', borderRadius: '0.375rem', marginBottom: '0.5rem' }}>
                      <div style={{ color: 'var(--text-secondary)', fontSize: '0.7rem', textTransform: 'uppercase' }}>MO Pattern</div>
                      <div>{selectedSuspect.modusOperandi}</div>
                    </div>
                    <div><span style={{ color: 'var(--text-secondary)' }}>Repeat Offender:</span> {selectedSuspect.isRepeatOffender ? '⚠️ Yes' : 'No'}</div>
                    <div><span style={{ color: 'var(--text-secondary)' }}>Known Associates:</span> {selectedSuspect.knownAssociates.length}</div>
                    <div><span style={{ color: 'var(--text-secondary)' }}>Last Known Location:</span> {selectedSuspect.lastKnownLocation.lat.toFixed(4)}, {selectedSuspect.lastKnownLocation.lng.toFixed(4)}</div>
                    <div><span style={{ color: 'var(--text-secondary)' }}>Last Seen:</span> {new Date(selectedSuspect.lastKnownLocation.timestamp).toLocaleString()}</div>
                  </div>
                </div>
              </div>

              {/* Criminal History */}
              <div className="card" style={{ marginTop: '1rem' }}>
                <h3 style={{ fontSize: '0.9rem', fontWeight: 600, marginBottom: '0.75rem', color: 'var(--accent-red)' }}>
                  🔗 Criminal History & Case Linkage ({suspectCases.length} cases)
                </h3>
                <div style={{ display: 'flex', flexDirection: 'column', gap: '0.5rem' }}>
                  {suspectCases.map(c => (
                    <div key={c.id} style={{
                      padding: '0.75rem',
                      background: 'rgba(0,0,0,0.2)',
                      borderRadius: '0.5rem',
                      border: '1px solid var(--border-color)',
                    }}>
                      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                        <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem' }}>
                          <span style={{
                            padding: '0.2rem 0.5rem', borderRadius: '0.25rem', fontSize: '0.65rem', fontWeight: 700,
                            background: `${c.crimeType === 'Murder' ? '#ef4444' : c.crimeType === 'Robbery' ? '#f97316' : '#3b82f6'}22`,
                            color: c.crimeType === 'Murder' ? '#ef4444' : c.crimeType === 'Robbery' ? '#f97316' : '#3b82f6',
                          }}>{c.crimeType}</span>
                          <span style={{ fontWeight: 600, fontSize: '0.85rem' }}>{c.id}</span>
                        </div>
                        <div style={{ fontSize: '0.7rem', color: 'var(--text-secondary)' }}>
                          {new Date(c.dateTime).toLocaleDateString('en-IN')}
                        </div>
                      </div>
                      <div style={{ marginTop: '0.35rem', fontSize: '0.75rem', color: 'var(--text-secondary)' }}>
                        {c.address.houseNumber}, {c.address.street}, {c.address.area} — {c.address.district}
                      </div>
                      <div style={{ marginTop: '0.25rem', display: 'flex', gap: '1rem', fontSize: '0.7rem' }}>
                        <span>Status: <b style={{
                          color: c.status === 'Solved' ? 'var(--accent-green)' : c.status === 'Under Investigation' ? 'var(--accent-yellow)' : 'var(--accent-blue)',
                        }}>{c.status}</b></span>
                        <span>Loss: ₹{c.victim.lossAmount.toLocaleString()}</span>
                        <span>Time: {c.timeSlot}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              {/* Known Associates Network */}
              {selectedSuspect.knownAssociates.length > 0 && (
                <div className="card" style={{ marginTop: '1rem' }}>
                  <h3 style={{ fontSize: '0.9rem', fontWeight: 600, marginBottom: '0.75rem', color: 'var(--accent-yellow)' }}>
                    🔗 Known Associates Network
                  </h3>
                  <div style={{ display: 'flex', gap: '0.5rem', flexWrap: 'wrap' }}>
                    {selectedSuspect.knownAssociates.map(aid => {
                      const assoc = allAccused.find(a => a.id === aid)
                      return assoc ? (
                        <div key={aid} onClick={() => setSelectedSuspect(assoc)} style={{
                          padding: '0.5rem 0.75rem',
                          background: 'rgba(0,0,0,0.2)',
                          borderRadius: '0.375rem',
                          border: '1px solid var(--border-color)',
                          cursor: 'pointer',
                          fontSize: '0.75rem',
                        }}>
                          <div style={{ fontWeight: 600 }}>{assoc.name}</div>
                          <div style={{ color: 'var(--text-secondary)', fontSize: '0.65rem' }}>Risk: {assoc.riskScore}/100</div>
                        </div>
                      ) : null
                    })}
                  </div>
                </div>
              )}
            </>
          ) : (
            <div className="card" style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', height: '300px' }}>
              <div style={{ textAlign: 'center', color: 'var(--text-secondary)' }}>
                <div style={{ fontSize: '3rem', marginBottom: '0.5rem' }}>🔍</div>
                <p>Select a suspect from the list to view detailed profile</p>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  )
}
